# ============================================================
# C1 Face Attendance — single root .env
# Copy this file to `.env` (same folder), then fill in real values.
# `.env` is gitignored. NEVER commit it.
# ============================================================

# ----- Backend (Python / FastAPI) ---------------------------
# Get from: https://supabase.com/dashboard/project/spccazagwlvrwdmpgmgt/settings/api-keys
SUPABASE_URL=https://spccazagwlvrwdmpgmgt.supabase.co
SUPABASE_SERVICE_KEY=replace_with_service_role_key_keep_secret
DB_SCHEMA=public
MOCK_AI=true
FACE_THRESHOLD=0.5
SPOOF_THRESHOLD=0.5
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ----- Frontend (Vite) --------------------------------------
# Only variables prefixed VITE_ are exposed to the browser bundle.
# NEVER put service_role / secret keys behind a VITE_ prefix.
VITE_SUPABASE_URL=https://spccazagwlvrwdmpgmgt.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_anon_or_publishable_key
VITE_FASTAPI_URL=http://localhost:8000
