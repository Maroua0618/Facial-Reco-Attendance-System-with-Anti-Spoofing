# Get keys from: https://supabase.com/dashboard/project/spccazagwlvrwdmpgmgt/settings/api-keys

SUPABASE_URL=https://spccazagwlvrwdmpgmgt.supabase.co
SUPABASE_SERVICE_KEY=replace_with_secret_key_starting_with_sb_secret_
DB_SCHEMA=public

# Set false for real AI (InsightFace + heuristic liveness).
# Run `python scripts/warmup.py` once before flipping to false.
MOCK_AI=true

# Cosine confidence floor (0..1). Higher = stricter face match.
FACE_THRESHOLD=0.5

# Liveness score floor (0..1). Higher = stricter spoof rejection.
# 0.65 catches phone-screen replays under good lighting; lower if too
# many real faces get rejected.
SPOOF_THRESHOLD=0.65

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
